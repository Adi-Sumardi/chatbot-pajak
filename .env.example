# Backend (.env di backend/)
DATABASE_URL=postgresql+asyncpg://chatbot_user:YOUR_DB_PASSWORD@localhost:5432/chatbot_pajak
JWT_SECRET_KEY=generate-random-secret-key-min-32-chars
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
CORS_ORIGINS=["https://chatbot.adilabs.id"]
UPLOAD_DIR=/opt/chatbot-pajak/backend/storage/uploads
EXPORT_DIR=/opt/chatbot-pajak/backend/storage/exports
DEBUG=false

# Frontend (.env.local di frontend/)
NEXT_PUBLIC_API_URL=https://chatbot.adilabs.id
